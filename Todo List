let todo = [];

let p = prompt("Please enter your request");

while (true) {
    if (p == "quit") {
        console.log("quit");
        break;
    }
    if (p == "list") {
        for (task of todo) {
            console.log(task);
        }
        console.log("----------------------");

    } else if (p == "add") {
        let newtask = prompt("Enter a new task");
        todo.push(newtask);
        console.log("Task added");

    } else if (p == "delete") {
        let idx = prompt("Please enter your request");
        todo.splice(idx, 1);
        console.log("Deleted task");

    } else {
        console.log("Invalid requests");
    }
    let p = prompt("Please enter your request");
}
